{
  "schema_version": 1,
  "id": "leaderboard.redis",
  "name": "Redis Leaderboard",
  "version": "1.0.0",
  "kind": "leaderboard",
  "description": "Redis ZSET provider for shield.leaderboard.v1 (multi-field composite score)",
  "entry": "shield_plugin_get_v1",
  "library": {
    "windows": "bin/libshield_leaderboard_redis.dll",
    "linux": "bin/libshield_leaderboard_redis.so",
    "macos": "bin/libshield_leaderboard_redis.dylib"
  },
  "provides": [
    { "interface": "shield.leaderboard.v1", "capabilities": ["sorted-set", "multi-field"] }
  ],
  "requires": [],
  "config_schema": {
    "type": "object",
    "required": ["host"],
    "properties": {
      "host": { "type": "string", "default": "127.0.0.1" },
      "port": { "type": "integer", "default": 6379, "minimum": 1, "maximum": 65535 },
      "password": { "type": "string", "secret": true },
      "db": { "type": "integer", "default": 0, "minimum": 0, "maximum": 15 },
      "connect_timeout_ms": { "type": "integer", "default": 5000, "minimum": 100, "maximum": 60000 },
      "command_timeout_ms": { "type": "integer", "default": 5000, "minimum": 100, "maximum": 60000 }
    }
  }
}
