{
  "schema_version": 1,
  "id": "auth.jwt",
  "name": "JWT Authentication",
  "version": "1.0.0",
  "kind": "auth",
  "description": "HS256 JWT provider for shield.auth.v1 (OpenSSL HMAC-SHA256)",
  "documentation": {
    "url": "https://cuihairu.github.io/shield/plugins/auth-jwt",
    "description": "HS256 JWT provider for the shield.auth.v1 interface (OpenSSL HMAC-SHA256)"
  },
  "entry": "shield_plugin_get_v1",
  "library": {
    "windows": "bin/libshield_auth_jwt.dll",
    "linux": "bin/libshield_auth_jwt.so",
    "macos": "bin/libshield_auth_jwt.dylib"
  },
  "provides": [
    { "interface": "shield.auth.v1", "capabilities": ["hs256", "stateless"] }
  ],
  "requires": [],
  "config_schema": {
    "type": "object",
    "required": ["secret"],
    "properties": {
      "secret": { "type": "string", "secret": true },
      "issuer": { "type": "string" },
      "audience": { "type": "string" },
      "token_ttl_seconds": { "type": "integer", "default": 3600, "minimum": 1, "maximum": 86400 },
      "leeway_seconds": { "type": "integer", "default": 60, "minimum": 0, "maximum": 3600 }
    }
  }
}
