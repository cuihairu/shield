        { "name": "yaml-cpp", "version>=": "0.9.0" },
        "nlohmann-json",
        "sol2",

        "boost-asio",
        "boost-beast",
        "boost-filesystem",
        "boost-log",
        "boost-program-options",
        "boost-test",
        "boost-url",
        "boost-dll",

        "openssl",
        "redis-plus-plus",

        "caf",
        "msgpack",

        "curl"
    ],
    "supports": "!uwp",
    "features": {
